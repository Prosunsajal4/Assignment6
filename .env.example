# Environment Configuration for Green Earth
# Copy this file to .env.local and fill in your credentials

# ============================================
# CLIENT CONFIGURATION (Vite)
# ============================================
VITE_API_URL=http://localhost:4242
VITE_API_TIMEOUT=30000
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here
VITE_APP_ENVIRONMENT=development
VITE_ENABLE_DEBUG=true

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4242
DOMAIN=http://localhost:3001

# ============================================
# STRIPE API KEYS
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys for development (sk_test_* and pk_test_*)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# ============================================
# EMAIL / SMTP CONFIGURATION
# ============================================
# For sending thank-you emails after donations
# Gmail requires an "App Password" (not your regular password)
# See: https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=Green Earth <noreply@greenearth.local>

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_SERVER_BASE=http://localhost:4242
