# Copy this file to .env and fill in your Stripe keys
# Example:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# DOMAIN=http://localhost:3001

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
DOMAIN=http://localhost:3001
STRIPE_WEBHOOK_SECRET=

# Optional SMTP settings for sending thank-you emails (used by server webhook handler)
# Example SMTP settings for Gmail SMTP (app password required):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# FROM_EMAIL="Green Earth <no-reply@yourdomain.com>"
